#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Point the current repo's origin at a GitHub SSH alias/account.

Usage:
  git-use <account>

Examples:
  git-use athackst
  git-use althack
EOF
}

ACCOUNT="${1:-}"

if [[ -z "$ACCOUNT" ]]; then
  usage
  exit 1
fi

if [[ "$ACCOUNT" == "-h" || "$ACCOUNT" == "--help" ]]; then
  usage
  exit 0
fi

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
  echo "Not inside a git repository." >&2
  exit 1
}

git remote get-url origin >/dev/null 2>&1 || {
  echo "Remote 'origin' does not exist." >&2
  exit 1
}

repo_name="$(basename -s .git "$(git rev-parse --show-toplevel)")"
new_url="git@github-${ACCOUNT}:${ACCOUNT}/${repo_name}.git"

git remote set-url origin "$new_url"
echo "origin -> $new_url"
