#!/usr/bin/env bash
set -euo pipefail

# md
# Removes duplicate files between two folders by comparing their checksums.
# If a file exists in both Folder A and Folder B, the file in Folder B will be deleted.
#
# ## Usage
#
# ```
# remove_dupes.sh <folder_a> <folder_b>
# ```
# /md

usage() {
    cat <<EOF
Usage: $0 [--refresh] <folder_a_path> <folder_b_path>

Deduplicate files between two folders by checksum.
If a file exists in both Folder A and Folder B, the file in Folder B is deleted.
EOF
}

REFRESH=false

while [[ $# -gt 0 ]]; do
    case "${1:-}" in
        -h|--help)
            usage
            exit 0
            ;;
        --refresh)
            REFRESH=true
            shift
            ;;
        *)
            break
            ;;
    esac
done

if [ "$#" -ne 2 ]; then
    usage
    exit 1
fi

folder_a="$1"
folder_b="$2"

# Validate if the provided folder paths exist
if [ ! -d "$folder_a" ]; then
    echo "Error: Folder A ($folder_a) does not exist."
    exit 1
fi

if [ ! -d "$folder_b" ]; then
    echo "Error: Folder B ($folder_b) does not exist."
    exit 1
fi

folder_a="$(realpath "$folder_a")"
folder_b="$(realpath "$folder_b")"

checksums_file() {
    local folder="$1"
    echo "$folder/.checksums"
}

write_checksums_manifest() {
    local folder="$1"
    local output="$2"

    echo "Computing checksums for $folder"
    (
        cd "$folder"
        find . -type f ! -name .checksums -print0 | while IFS= read -r -d '' file; do
            local_path="${file#./}"
            checksum="$(md5sum "$local_path" | awk '{print $1}')"
            printf '%s  %s\n' "$checksum" "$local_path"
        done
    ) > "$output"
}

folder_a_checksums="$(checksums_file "$folder_a")"
folder_b_checksums="$(checksums_file "$folder_b")"

if $REFRESH || [ ! -f "$folder_a_checksums" ]; then
    write_checksums_manifest "$folder_a" "$folder_a_checksums"
else
    echo "Using cached checksums for $folder_a"
fi

if $REFRESH || [ ! -f "$folder_b_checksums" ]; then
    write_checksums_manifest "$folder_b" "$folder_b_checksums"
else
    echo "Using cached checksums for $folder_b"
fi

awk '{print $1}' "$folder_a_checksums" | sort -u | while read -r checksum_a; do
    while IFS= read -r matched_line; do
        relative_path="${matched_line#*  }"
        file_b="$folder_b/$relative_path"
        if [ -n "$file_b" ] && [ -f "$file_b" ]; then
            rm "$file_b"
            echo "Deleted: $file_b"
        fi
    done < <(grep "^${checksum_a}  " "$folder_b_checksums" || true)
done
