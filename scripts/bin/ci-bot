#!/usr/bin/env python3
"""Manage CI template setup and token distribution for GitHub repositories."""

from __future__ import annotations

import argparse
import json
import os
import shlex
import shutil
import subprocess
import sys
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path
from typing import Any


# ---------------------------------------------------------------------------
# Config and data models


DEFAULT_SOURCE = "gh:athackst/ci"
DEFAULT_TEMPLATE_REF = "main"
DEFAULT_ANSWERS_FILE = ".copier-answers.ci.yml"
DEFAULT_SECRET_NAME = "CI_BOT_TOKEN"
DEFAULT_TOKEN_FILE = Path("~/.config/tokens/ci_bot.token").expanduser()
DEFAULT_TOKEN_DIR = Path("~/.config/tokens").expanduser()
DEFAULT_REGISTRY_PATH = Path("~/.config/ci_bot/repos.json").expanduser()
SECRET_SCOPES = ("repo", "org")


class CIBotError(Exception):
    """User-facing CLI error."""


@dataclass
class RepoConfig:
    repo: str
    source: str = DEFAULT_SOURCE
    template_ref: str = DEFAULT_TEMPLATE_REF
    secret_name: str = DEFAULT_SECRET_NAME
    secret_scope: str = "repo"
    secret_org: str | None = None
    path: str | None = None
    token_file: str | None = None
    added_at: str | None = None
    last_setup_at: str | None = None
    last_update_at: str | None = None
    last_token_refresh_at: str | None = None

    @classmethod
    def from_dict(cls, repo: str, data: dict[str, Any]) -> "RepoConfig":
        return cls(
            repo=repo,
            source=data.get("source", DEFAULT_SOURCE),
            template_ref=data.get("template_ref", DEFAULT_TEMPLATE_REF),
            secret_name=data.get("secret_name", DEFAULT_SECRET_NAME),
            secret_scope=data.get("secret_scope", "repo"),
            secret_org=data.get("secret_org"),
            path=data.get("path"),
            token_file=data.get("token_file"),
            added_at=data.get("added_at"),
            last_setup_at=data.get("last_setup_at"),
            last_update_at=data.get("last_update_at"),
            last_token_refresh_at=data.get("last_token_refresh_at"),
        )

    def to_patch(self) -> dict[str, Any]:
        values = {
            "source": self.source,
            "template_ref": self.template_ref,
            "secret_name": self.secret_name,
            "secret_scope": self.secret_scope,
            "secret_org": self.secret_org,
            "path": self.path,
            "token_file": self.token_file,
            "added_at": self.added_at,
            "last_setup_at": self.last_setup_at,
            "last_update_at": self.last_update_at,
            "last_token_refresh_at": self.last_token_refresh_at,
        }
        return {key: value for key, value in values.items() if value is not None}


@dataclass
class TokenResult:
    value: str
    source_path: str | None


@dataclass
class SetupOptions:
    repo: str
    source: str
    template_ref: str
    secret_name: str
    secret_scope: str
    secret_org: str | None
    token_file: str | None
    skip_secret: bool
    copier_interactive: bool
    cwd: str
    walkthrough: bool


# ---------------------------------------------------------------------------
# Low-level utilities


def now_utc() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def echo(msg: str = "", err: bool = False) -> None:
    print(msg, file=sys.stderr if err else sys.stdout, flush=True)


class Shell:
    @staticmethod
    def require(cmd: str) -> None:
        if not shutil.which(cmd):
            raise CIBotError(f"Missing required command: {cmd}")

    @staticmethod
    def run(
        cmd: list[str],
        cwd: str | None = None,
        capture_output: bool = False,
        input_text: str | None = None,
        display_cmd: list[str] | None = None,
    ) -> str | None:
        try:
            completed = subprocess.run(
                cmd,
                cwd=cwd,
                check=True,
                text=True,
                input=input_text,
                capture_output=capture_output,
            )
        except subprocess.CalledProcessError as exc:
            stderr = (exc.stderr or "").strip()
            stdout = (exc.stdout or "").strip()
            shown_cmd = display_cmd or cmd
            detail = stderr or stdout or f"Command failed: {' '.join(shown_cmd)}"
            raise CIBotError(detail) from exc
        if capture_output:
            return (completed.stdout or "").strip()
        return None


class Prompts:
    @staticmethod
    def text(prompt: str, default: str | None = None) -> str:
        suffix = f" [{default}]" if default else ""
        value = input(f"{prompt}{suffix}: ").strip()
        return value or (default or "")

    @staticmethod
    def required(prompt: str, default: str | None = None) -> str:
        value = Prompts.text(prompt, default)
        if not value:
            raise CIBotError(f"{prompt} is empty; refusing to continue.")
        return value

    @staticmethod
    def confirm(prompt: str, default: bool) -> bool:
        suffix = "Y/n" if default else "y/N"
        while True:
            value = input(f"{prompt} [{suffix}]: ").strip().lower()
            if not value:
                return default
            if value in {"y", "yes"}:
                return True
            if value in {"n", "no"}:
                return False
            echo("Please answer yes or no.", err=True)

    @staticmethod
    def choice(prompt: str, options: list[str], default: int | None = None) -> int:
        if not options:
            raise CIBotError(f"{prompt} has no available options.")
        for index, option in enumerate(options, start=1):
            marker = " (default)" if default == index else ""
            echo(f"  {index}. {option}{marker}")
        while True:
            suffix = f" [{default}]" if default is not None else ""
            value = input(f"{prompt}{suffix}: ").strip()
            if not value and default is not None:
                return default - 1
            try:
                selected = int(value)
            except ValueError:
                echo(f"Enter a number between 1 and {len(options)}.", err=True)
                continue
            if 1 <= selected <= len(options):
                return selected - 1
            echo(f"Enter a number between 1 and {len(options)}.", err=True)

    @staticmethod
    def token() -> str:
        token_value = normalize_token(input("Enter CI token: "))
        if not token_value:
            raise CIBotError("Token value is empty; refusing to continue.")
        return token_value


def normalize_token(token: str) -> str:
    return token.strip()


def normalize_token_name(name: str) -> str:
    normalized = name.strip()
    if not normalized:
        raise CIBotError("Token name is empty; refusing to continue.")
    if "/" in normalized or "\\" in normalized:
        raise CIBotError("Token name must not contain path separators.")
    return normalized


def token_file_for_name(name: str) -> Path:
    return DEFAULT_TOKEN_DIR / f"{normalize_token_name(name)}.token"


def split_repo(repo: str) -> tuple[str, str]:
    parts = repo.split("/", 1)
    if len(parts) != 2 or not parts[0] or not parts[1]:
        raise CIBotError(f"Repository must be in owner/repo form: {repo}")
    return parts[0], parts[1]


def normalize_secret_scope(scope: str | None) -> str:
    normalized = (scope or "repo").strip().lower()
    if normalized not in SECRET_SCOPES:
        raise CIBotError(f"Secret scope must be one of: {', '.join(SECRET_SCOPES)}")
    return normalized


def repo_name_for_org(repo: str, org: str) -> str:
    owner, name = split_repo(repo)
    if owner != org:
        raise CIBotError(f"Repo '{repo}' is not in org '{org}'.")
    return name


def org_repo_names(repos: str, org: str) -> list[str]:
    names: list[str] = []
    for value in repos.split(","):
        repo = value.strip()
        if not repo:
            continue
        if "/" in repo:
            names.append(repo_name_for_org(repo, org))
        else:
            names.append(repo)
    if not names:
        raise CIBotError("Provide at least one repo for an org secret.")
    return sorted(set(names))


# ---------------------------------------------------------------------------
# Registry, GitHub, Copier, and token services


class Registry:
    def __init__(self, path: Path):
        self.path = path
        self.data = self._load()

    def _load(self) -> dict[str, Any]:
        if not self.path.exists():
            return {"repos": {}, "tokens": {}}
        try:
            data = json.loads(self.path.read_text(encoding="utf-8"))
        except json.JSONDecodeError as exc:
            raise CIBotError(f"Registry file is not valid JSON: {self.path}") from exc
        if not isinstance(data, dict):
            raise CIBotError(f"Registry file must contain a JSON object: {self.path}")
        data.setdefault("repos", {})
        data.setdefault("tokens", {})
        data.setdefault("org_secrets", {})
        if not isinstance(data["repos"], dict):
            raise CIBotError(f"Registry file 'repos' field must be an object: {self.path}")
        if not isinstance(data["tokens"], dict):
            raise CIBotError(f"Registry file 'tokens' field must be an object: {self.path}")
        if not isinstance(data["org_secrets"], dict):
            raise CIBotError(f"Registry file 'org_secrets' field must be an object: {self.path}")
        return data

    def save(self) -> None:
        self.path.parent.mkdir(parents=True, exist_ok=True)
        self.path.write_text(json.dumps(self.data, indent=2, sort_keys=True) + "\n", encoding="utf-8")

    def repo(self, repo: str) -> RepoConfig | None:
        data = self.data["repos"].get(repo)
        if data is None:
            return None
        return RepoConfig.from_dict(repo, data)

    def require_repo(self, repo: str) -> RepoConfig:
        config = self.repo(repo)
        if config is None:
            raise CIBotError(f"Repo '{repo}' is not registered. Run 'ci-bot setup' or 'ci-bot repo add --repo {repo}'.")
        return config

    def upsert_repo(self, config: RepoConfig) -> None:
        existing = self.data["repos"].get(config.repo, {})
        merged = {**existing, **config.to_patch()}
        self.data["repos"][config.repo] = merged

    def remove_repo(self, repo: str) -> None:
        if self.data["repos"].pop(repo, None) is None:
            raise CIBotError(f"Repo '{repo}' is not registered.")

    def register_token_file(self, token_file: Path, name: str | None = None) -> None:
        token_path = str(token_file.expanduser())
        existing = self.data.setdefault("tokens", {}).get(token_path, {})
        token_data = {
            **existing,
            "path": token_path,
            "added_at": existing.get("added_at", now_utc()),
        }
        if name:
            token_data["name"] = normalize_token_name(name)
        self.data["tokens"][token_path] = token_data

    def token_label(self, token_file: str | None) -> str:
        if not token_file:
            return "-"
        token_data = self.data.get("tokens", {}).get(token_file, {})
        return token_data.get("name") or token_file

    def org_secret_key(self, org: str, secret_name: str) -> str:
        return f"{org}/{secret_name}"

    def upsert_org_secret(
        self,
        org: str,
        secret_name: str,
        token_file: str | None,
        repos: list[str],
        visibility: str = "selected",
        last_token_refresh_at: str | None = None,
    ) -> None:
        key = self.org_secret_key(org, secret_name)
        existing = self.data.setdefault("org_secrets", {}).get(key, {})
        merged_repos = sorted(set(existing.get("repos", [])) | set(repos))
        org_secret = {
            **existing,
            "org": org,
            "secret_name": secret_name,
            "visibility": visibility,
            "repos": merged_repos,
            "added_at": existing.get("added_at", now_utc()),
        }
        if token_file is not None:
            org_secret["token_file"] = token_file
        if last_token_refresh_at is not None:
            org_secret["last_token_refresh_at"] = last_token_refresh_at
        self.data["org_secrets"][key] = org_secret

    def repos_using_token(self, token_file: Path) -> list[RepoConfig]:
        token_path = str(token_file.expanduser())
        configs: list[RepoConfig] = []
        for repo_name in sorted(self.data["repos"].keys()):
            config = self.repo(repo_name)
            if config and config.token_file == token_path:
                configs.append(config)
        return configs

    def org_secrets_using_token(self, token_file: Path) -> list[dict[str, Any]]:
        token_path = str(token_file.expanduser())
        secrets: list[dict[str, Any]] = []
        for data in self.data.get("org_secrets", {}).values():
            if data.get("token_file") == token_path:
                secrets.append(data)
        return sorted(secrets, key=lambda item: (item.get("org", ""), item.get("secret_name", "")))


class GitHub:
    def auth_status(self) -> subprocess.CompletedProcess[str]:
        Shell.require("gh")
        return subprocess.run(
            ["gh", "auth", "status", "-h", "github.com"],
            text=True,
            capture_output=True,
            check=False,
        )

    def auth_command_for_org_secrets(self) -> list[str]:
        status = self.auth_status()
        if status.returncode == 0:
            return ["gh", "auth", "refresh", "-h", "github.com", "-s", "admin:org"]
        return ["gh", "auth", "login", "-h", "github.com", "-s", "admin:org"]

    def prompt_for_repo_secret_auth(self, detail: str, repo: str) -> bool:
        owner, _name = split_repo(repo)
        switch_cmd = ["gh", "auth", "switch", "-h", "github.com", "-u", owner]
        refresh_cmd = ["gh", "auth", "refresh", "-h", "github.com", "-s", "repo"]
        login_cmd = ["gh", "auth", "login", "-h", "github.com", "-s", "repo"]
        switch_text = " ".join(shlex.quote(part) for part in switch_cmd)
        refresh_text = " ".join(shlex.quote(part) for part in refresh_cmd)
        login_text = " ".join(shlex.quote(part) for part in login_cmd)
        if not sys.stdin.isatty():
            raise CIBotError(
                f"{detail}\n"
                f"ci-bot needs GitHub repo secret permission for {repo}. "
                f"Run `{switch_text}` and `{refresh_text}`, then try again. "
                f"If {owner} is not configured in gh yet, run `{login_text}` while signed in as {owner}."
            )
        echo(detail, err=True)
        if not Prompts.confirm(f"Switch gh to {owner} and authorize repo secrets for {repo} now?", True):
            raise CIBotError(f"Run `{switch_text}` and `{refresh_text}`, then try again.")
        try:
            Shell.run(switch_cmd)
        except CIBotError:
            echo(f"Could not switch gh to {owner}; starting a new gh login. Use the {owner} account in the browser.", err=True)
            Shell.run(login_cmd)
            return True
        Shell.run(refresh_cmd)
        return True

    def prompt_for_org_secret_auth(self, detail: str, org: str) -> bool:
        cmd = self.auth_command_for_org_secrets()
        command_text = " ".join(shlex.quote(part) for part in cmd)
        if not sys.stdin.isatty():
            raise CIBotError(
                f"{detail}\n"
                f"ci-bot needs GitHub organization secret permission for {org}. "
                f"Run `{command_text}` and try again."
            )
        echo(detail, err=True)
        if not Prompts.confirm(f"Authorize gh for organization secrets on {org} now by running `{command_text}`?", True):
            raise CIBotError(f"Run `{command_text}` and try again.")
        Shell.run(cmd)
        return True

    def detect_repo(self) -> str:
        Shell.require("gh")
        value = Shell.run(["gh", "repo", "view", "--json", "nameWithOwner", "--jq", ".nameWithOwner"], capture_output=True)
        if not value:
            raise CIBotError("Could not detect repository.")
        return value

    def maybe_detect_repo(self) -> str | None:
        try:
            return self.detect_repo()
        except CIBotError:
            return None

    def set_secret(self, repo: str, secret_name: str, token_value: str, allow_auth_prompt: bool = True) -> None:
        Shell.require("gh")
        cmd = ["gh", "secret", "set", secret_name, "--repo", repo]
        try:
            Shell.run(cmd, input_text=f"{token_value}\n")
        except CIBotError as exc:
            detail = str(exc)
            if "failed to fetch public key" in detail or "HTTP 403" in detail or "token" in detail.lower():
                if allow_auth_prompt and self.prompt_for_repo_secret_auth(detail, repo):
                    self.set_secret(repo, secret_name, token_value, allow_auth_prompt=False)
                    return
                raise CIBotError(
                    f"{detail}\n"
                    f"gh is authenticated, but it does not have permission to manage Actions secrets for {repo}. "
                    "Run `gh auth refresh -h github.com -s repo`, confirm the correct GitHub account is active, "
                    "and ensure the credential has repository access plus GitHub Actions secrets permission."
                ) from exc
            raise

    def set_org_secret(
        self,
        org: str,
        secret_name: str,
        token_value: str,
        repos: list[str],
        visibility: str = "selected",
        allow_auth_prompt: bool = True,
    ) -> None:
        Shell.require("gh")
        cmd = ["gh", "secret", "set", secret_name, "--org", org, "--visibility", visibility]
        if visibility == "selected":
            if not repos:
                raise CIBotError("Selected org secrets require at least one repo.")
            cmd.extend(["--repos", ",".join(sorted(repos))])
        try:
            Shell.run(cmd, input_text=f"{token_value}\n", capture_output=True)
        except CIBotError as exc:
            detail = str(exc)
            if "HTTP 403" in detail or "admin:org" in detail:
                if allow_auth_prompt and self.prompt_for_org_secret_auth(detail, org):
                    self.set_org_secret(org, secret_name, token_value, repos, visibility, allow_auth_prompt=False)
                    return
                raise CIBotError(
                    f"{detail}\n"
                    f"gh is authenticated, but it does not have permission to manage organization secrets for {org}. "
                    "Run `gh auth refresh -h github.com -s admin:org` and try again."
                ) from exc
            raise


class Copier:
    def apply(self, source: str, template_ref: str, copier_interactive: bool, cwd: str) -> None:
        Shell.require("copier")
        cmd = [
            "copier",
            "copy",
            "--trust",
            "--vcs-ref",
            template_ref,
            "--answers-file",
            DEFAULT_ANSWERS_FILE,
        ]
        if not copier_interactive:
            cmd.append("--defaults")
        cmd.extend([source, "."])
        echo(f"Applying template {source}@{template_ref} in {cwd}")
        Shell.run(cmd, cwd=cwd)

    def update(self, template_ref: str, copier_interactive: bool, cwd: str) -> None:
        Shell.require("copier")
        cmd = [
            "copier",
            "update",
            "--trust",
            "--vcs-ref",
            template_ref,
            "--answers-file",
            DEFAULT_ANSWERS_FILE,
        ]
        if not copier_interactive:
            cmd.append("--defaults")
        echo(f"Updating template in {cwd} with ref {template_ref}")
        Shell.run(cmd, cwd=cwd)


class TokenStore:
    def write(self, token_file: Path, token_value: str) -> str:
        token_file.parent.mkdir(parents=True, exist_ok=True)
        token_file.write_text(f"{token_value}\n", encoding="utf-8")
        echo(f"Saved token to {token_file}")
        return str(token_file)

    def resolve(self, token_file: str | None = None) -> TokenResult:
        requested_path = Path(token_file).expanduser() if token_file else None

        if requested_path and requested_path.is_file():
            return TokenResult(normalize_token(requested_path.read_text(encoding="utf-8")), str(requested_path))

        if requested_path:
            token_value = Prompts.token()
            return TokenResult(token_value, self.write(requested_path, token_value))

        env_token = normalize_token(os.environ.get("CI_BOT_TOKEN", ""))
        if env_token:
            return TokenResult(env_token, None)

        if DEFAULT_TOKEN_FILE.is_file():
            return TokenResult(normalize_token(DEFAULT_TOKEN_FILE.read_text(encoding="utf-8")), str(DEFAULT_TOKEN_FILE))

        token_value = Prompts.token()
        return TokenResult(token_value, self.write(DEFAULT_TOKEN_FILE, token_value))

    def resolve_supplied(self, token: str | None, token_file: Path) -> TokenResult:
        token_file = token_file.expanduser()
        if token is not None:
            token_value = normalize_token(token)
            if not token_value:
                raise CIBotError("Token value is empty; refusing to continue.")
            return TokenResult(token_value, self.write(token_file, token_value))

        if token_file.is_file():
            token_value = normalize_token(token_file.read_text(encoding="utf-8"))
            if token_value:
                return TokenResult(token_value, str(token_file))

        token_value = Prompts.token()
        return TokenResult(token_value, self.write(token_file, token_value))

    def resolve_repo_token_file(self, registry: Registry, name: str | None) -> str:
        if name:
            token_name = normalize_token_name(name)
        elif sys.stdin.isatty():
            token_name = normalize_token_name(Prompts.required("Token name"))
        else:
            raise CIBotError("Provide --token-name or --token-file.")
        token_file = token_file_for_name(token_name)
        if not token_file.is_file():
            self.resolve_supplied(None, token_file)
        registry.register_token_file(token_file, token_name)
        return str(token_file)


class Services:
    def __init__(self, registry_path: Path, github: GitHub, copier: Copier, tokens: TokenStore):
        self.registry_path = registry_path
        self.github = github
        self.copier = copier
        self.tokens = tokens
        self._registry: Registry | None = None

    @property
    def registry(self) -> Registry:
        if self._registry is None or self._registry.path != self.registry_path:
            self._registry = Registry(self.registry_path)
        return self._registry


# ---------------------------------------------------------------------------
# Command workflows


class Commands:
    def __init__(self, services: Services):
        self.services = services

    def prompt_or_error(self, message: str, prompt: str, default: str | None = None) -> str:
        if sys.stdin.isatty():
            return Prompts.required(prompt, default)
        raise CIBotError(message)

    def repo_or_detect_or_prompt(self, repo: str | None) -> str:
        if repo:
            return repo
        if sys.stdin.isatty():
            return Prompts.required("Repository (owner/repo)", self.services.github.maybe_detect_repo())
        return self.services.github.detect_repo()

    def token_file_or_prompt(
        self,
        name: str | None,
        token_file: str | None,
        default_token_file: str | None = None,
    ) -> Path:
        if token_file:
            return Path(token_file).expanduser()
        if name:
            return token_file_for_name(name)
        if sys.stdin.isatty():
            return self.prompt_for_token_file("Select token", default_token_file)
        raise CIBotError("Provide a token name or --token-file.")

    def token_name_default_from_file(self, token_file: str | None) -> str | None:
        if not token_file:
            return None
        path = Path(token_file).expanduser()
        if path.parent != DEFAULT_TOKEN_DIR or path.suffix != ".token":
            return None
        return path.stem

    def registered_token_choices(self, default_token_file: str | None = None) -> list[tuple[str, Path]]:
        tokens = self.services.registry.data.get("tokens", {})
        repo_token_paths: set[str] = set()
        for repo_name in sorted(self.services.registry.data["repos"].keys()):
            config = self.services.registry.repo(repo_name)
            if config and config.token_file:
                repo_token_paths.add(str(Path(config.token_file).expanduser()))
        for org_secret in self.services.registry.data.get("org_secrets", {}).values():
            token_file = org_secret.get("token_file")
            if token_file:
                repo_token_paths.add(str(Path(token_file).expanduser()))

        all_token_paths = sorted(set(tokens) | repo_token_paths)
        choices: list[tuple[str, Path]] = []
        seen: set[str] = set()
        for token_path in all_token_paths:
            path = Path(token_path).expanduser()
            token_data = tokens.get(str(path), {})
            name = token_data.get("name") or self.token_name_default_from_file(str(path))
            label = f"{name} ({path})" if name else str(path)
            choices.append((label, path))
            seen.add(str(path))

        if default_token_file:
            default_path = Path(default_token_file).expanduser()
            default_key = str(default_path)
            if default_key not in seen:
                default_name = self.token_name_default_from_file(default_key)
                label = f"{default_name} ({default_path})" if default_name else str(default_path)
                choices.append((label, default_path))

        return choices

    def prompt_for_token_file(self, prompt: str, default_token_file: str | None = None) -> Path:
        default_path = Path(default_token_file).expanduser() if default_token_file else None
        choices = self.registered_token_choices(default_token_file)
        options = [label for label, _path in choices]
        options.append("Add new token")

        default_index: int | None = None
        if default_path is not None:
            for index, (_label, path) in enumerate(choices, start=1):
                if path == default_path:
                    default_index = index
                    break

        selected = Prompts.choice(prompt, options, default_index)
        if selected == len(choices):
            return self.create_and_register_token(self.token_name_default_from_file(default_token_file))
        return choices[selected][1]

    def create_and_register_token(self, default_name: str | None = None) -> Path:
        token_name = normalize_token_name(Prompts.required("Token name", default_name))
        token_file = token_file_for_name(token_name)
        self.services.tokens.resolve_supplied(None, token_file)
        self.services.registry.register_token_file(token_file, token_name)
        self.services.registry.save()
        echo(f"Registered token file {token_file}")
        return token_file

    def register_selected_token_file(self, token_file: Path) -> str:
        expanded = token_file.expanduser()
        self.services.registry.register_token_file(expanded, self.token_name_default_from_file(str(expanded)))
        return str(expanded)

    def secret_scope_from_args(self, args: argparse.Namespace, existing: RepoConfig | None = None) -> str:
        return normalize_secret_scope(getattr(args, "secret_scope", None) or (existing.secret_scope if existing else "repo"))

    def secret_org_for_repo(self, repo: str, scope: str, requested_org: str | None, existing: RepoConfig | None = None) -> str | None:
        if scope != "org":
            return None
        if requested_org:
            return requested_org
        if existing and existing.secret_org:
            return existing.secret_org
        owner, _name = split_repo(repo)
        return owner

    def set_secret_for_repo(
        self,
        repo: str,
        secret_name: str,
        scope: str,
        org: str | None,
        token: TokenResult,
        timestamp: str,
    ) -> None:
        if scope == "org":
            if not org:
                raise CIBotError("Organization secret scope requires --org.")
            org_repo = repo_name_for_org(repo, org)
            echo(f"Using secret from {token.source_path or 'inline value'} to set org secret '{secret_name}' on {org} for {org_repo}")
            self.services.github.set_org_secret(org, secret_name, token.value, [org_repo])
            self.services.registry.upsert_org_secret(
                org=org,
                secret_name=secret_name,
                token_file=token.source_path,
                repos=[org_repo],
                last_token_refresh_at=timestamp,
            )
            return

        echo(f"Using secret from {token.source_path or 'inline value'} to set repo secret '{secret_name}' on {repo}")
        self.services.github.set_secret(repo, secret_name, token.value)

    def secret_label(self, data: dict[str, Any]) -> str:
        secret_name = data.get("secret_name", DEFAULT_SECRET_NAME)
        scope = data.get("secret_scope", "repo")
        if scope == "org":
            org = data.get("secret_org") or split_repo(data.get("repo", "-/-"))[0]
            return f"org:{org}/{secret_name}"
        return f"repo:{secret_name}"

    def resolve_setup_options(self, args: argparse.Namespace) -> SetupOptions:
        walkthrough = sys.stdin.isatty()
        detected_repo = args.repo or (self.services.github.maybe_detect_repo() if walkthrough else self.services.github.detect_repo())

        if walkthrough:
            echo("ci-bot setup")
            echo("This will apply the CI template, configure the GitHub secret, and register this repo.")

        repo = args.repo or (Prompts.required("Repository (owner/repo)", detected_repo) if walkthrough else detected_repo)
        source = args.source or (Prompts.text("Copier template source", DEFAULT_SOURCE) if walkthrough else DEFAULT_SOURCE)
        template_ref = args.template_ref or (Prompts.text("Copier template ref", DEFAULT_TEMPLATE_REF) if walkthrough else DEFAULT_TEMPLATE_REF)

        skip_secret = args.skip_secret
        if not skip_secret and walkthrough:
            skip_secret = not Prompts.confirm("Set the GitHub Actions secret now?", True)

        secret_name = args.secret_name or (
            Prompts.text("GitHub Actions secret name", DEFAULT_SECRET_NAME)
            if walkthrough and not skip_secret
            else DEFAULT_SECRET_NAME
        )
        secret_scope = normalize_secret_scope(args.secret_scope)
        secret_org = self.secret_org_for_repo(repo, secret_scope, args.org)

        copier_interactive = args.interactive
        if not copier_interactive and walkthrough:
            copier_interactive = Prompts.confirm("Prompt for Copier template values?", False)

        token_file = str(Path(args.token_file).expanduser()) if args.token_file else None
        if not token_file and walkthrough and not skip_secret:
            token_file = str(self.prompt_for_token_file("Select token", str(DEFAULT_TOKEN_FILE)))

        return SetupOptions(
            repo=repo,
            source=source,
            template_ref=template_ref,
            secret_name=secret_name,
            secret_scope=secret_scope,
            secret_org=secret_org,
            token_file=token_file,
            skip_secret=skip_secret,
            copier_interactive=copier_interactive,
            cwd=os.getcwd(),
            walkthrough=walkthrough,
        )

    def setup(self, args: argparse.Namespace) -> None:
        Shell.require("git")
        options = self.resolve_setup_options(args)

        if options.walkthrough:
            echo()
            echo("Step 1: Apply the CI template")
        self.services.copier.apply(options.source, options.template_ref, options.copier_interactive, options.cwd)

        token: TokenResult | None = None
        if not options.skip_secret:
            if options.walkthrough:
                echo()
                echo("Step 2: Configure the GitHub Actions secret")
            token = self.services.tokens.resolve(options.token_file)
            if token.source_path is not None:
                self.register_selected_token_file(Path(token.source_path))
            self.set_secret_for_repo(
                options.repo,
                options.secret_name,
                options.secret_scope,
                options.secret_org,
                token,
                now_utc(),
            )
        elif options.walkthrough:
            echo()
            echo("Step 2: Skip GitHub Actions secret")

        if options.walkthrough:
            echo()
            echo("Step 3: Register this repo locally")

        timestamp = now_utc()
        existing = self.services.registry.repo(options.repo)
        self.services.registry.upsert_repo(
            RepoConfig(
                repo=options.repo,
                source=options.source,
                template_ref=options.template_ref,
                secret_name=options.secret_name,
                secret_scope=options.secret_scope,
                secret_org=options.secret_org,
                path=options.cwd,
                token_file=token.source_path if token else options.token_file,
                added_at=existing.added_at if existing else timestamp,
                last_setup_at=timestamp,
                last_token_refresh_at=timestamp if token else None,
            )
        )
        self.services.registry.save()
        echo(f"Registered {options.repo} in {self.services.registry.path}")

    def update(self, args: argparse.Namespace) -> None:
        repo = self.repo_or_detect_or_prompt(args.repo)
        config = self.services.registry.require_repo(repo)
        target_path = Path(args.path).expanduser() if args.path else Path(config.path or os.getcwd()).expanduser()
        if not target_path.exists():
            raise CIBotError(f"Repo path does not exist: {target_path}. Re-run setup here or pass --path.")

        template_ref = args.template_ref or config.template_ref
        copier_interactive = args.interactive
        if not copier_interactive and sys.stdin.isatty():
            copier_interactive = Prompts.confirm("Prompt for Copier values?", False)
        self.services.copier.update(template_ref, copier_interactive, str(target_path))
        config.path = str(target_path)
        config.template_ref = template_ref
        config.last_update_at = now_utc()
        self.services.registry.upsert_repo(config)
        self.services.registry.save()
        echo(f"Updated registry for {repo}")

    def token_add(self, args: argparse.Namespace) -> None:
        if args.token_file:
            token_file = Path(args.token_file).expanduser()
            if not token_file.is_file() or args.token is not None:
                self.services.tokens.resolve_supplied(args.token, token_file)
            self.services.registry.register_token_file(token_file, args.name)
            self.services.registry.save()
            echo(f"Registered token file {token_file}")
            return

        if args.token is None and args.name is None and sys.stdin.isatty():
            self.create_and_register_token()
            return

        name = args.name or self.prompt_or_error("Provide a token name or --token-file.", "Token name")
        token_file = token_file_for_name(name)
        self.services.tokens.resolve_supplied(args.token, token_file)
        self.services.registry.register_token_file(token_file, name)
        self.services.registry.save()
        echo(f"Registered token file {token_file}")

    def token_list(self, _args: argparse.Namespace) -> None:
        token_files: dict[str, list[str]] = {}
        org_token_files: dict[str, list[str]] = {}
        registered_tokens = self.services.registry.data.get("tokens", {})
        for repo_name in sorted(self.services.registry.data["repos"].keys()):
            config = self.services.registry.repo(repo_name)
            if config and config.token_file:
                token_files.setdefault(config.token_file, []).append(repo_name)
        for key, org_secret in self.services.registry.data.get("org_secrets", {}).items():
            token_file = org_secret.get("token_file")
            if token_file:
                org_token_files.setdefault(token_file, []).append(key)

        all_token_paths = sorted(set(token_files) | set(org_token_files) | set(registered_tokens))
        if not all_token_paths:
            echo("No token files registered.")
            return
        for token_file in all_token_paths:
            repos = token_files.get(token_file, [])
            org_secrets = org_token_files.get(token_file, [])
            token_data = registered_tokens.get(token_file, {})
            name = token_data.get("name")
            name_part = f"name={name}\t" if name else ""
            echo(f"{token_file}\t{name_part}{len(repos)} repo(s)\t{len(org_secrets)} org secret(s)")

    def token_show(self, args: argparse.Namespace) -> None:
        token_file = self.token_file_or_prompt(args.name, args.token_file)
        if not token_file.is_file():
            raise CIBotError(f"Token file does not exist: {token_file}")
        echo(normalize_token(token_file.read_text(encoding="utf-8")))

    def token_refresh(self, args: argparse.Namespace) -> None:
        token_file = self.token_file_or_prompt(args.name, args.token_file)
        if args.token is not None:
            token = self.services.tokens.resolve_supplied(args.token, token_file)
        elif token_file.is_file() and sys.stdin.isatty() and Prompts.confirm("Save a new token value before refreshing repos?", False):
            token_value = Prompts.token()
            token = TokenResult(token_value, self.services.tokens.write(token_file, token_value))
        else:
            token = self.services.tokens.resolve_supplied(None, token_file)
        repo_targets = self.services.registry.repos_using_token(token_file)
        org_targets = self.services.registry.org_secrets_using_token(token_file)
        if not repo_targets and not org_targets:
            raise CIBotError(f"No registered repos use token file: {token_file}")

        timestamp = now_utc()
        refreshed_org_keys: set[str] = set()
        for org_secret in org_targets:
            org = org_secret["org"]
            secret_name = org_secret["secret_name"]
            repos = org_secret.get("repos", [])
            echo(f"Using secret from {token.source_path} to set org secret '{secret_name}' on {org} for {len(repos)} repo(s)")
            self.services.github.set_org_secret(org, secret_name, token.value, repos, org_secret.get("visibility", "selected"))
            self.services.registry.upsert_org_secret(
                org=org,
                secret_name=secret_name,
                token_file=str(token_file.expanduser()),
                repos=repos,
                visibility=org_secret.get("visibility", "selected"),
                last_token_refresh_at=timestamp,
            )
            refreshed_org_keys.add(self.services.registry.org_secret_key(org, secret_name))

        org_repo_targets: dict[str, tuple[str, str, list[str]]] = {}
        for config in repo_targets:
            if config.secret_scope == "org":
                org = config.secret_org or split_repo(config.repo)[0]
                key = self.services.registry.org_secret_key(org, config.secret_name)
                if key in refreshed_org_keys:
                    continue
                org_repo = repo_name_for_org(config.repo, org)
                _org, _secret_name, repos = org_repo_targets.setdefault(key, (org, config.secret_name, []))
                repos.append(org_repo)

        for key, (org, secret_name, repos) in org_repo_targets.items():
            repos = sorted(set(repos))
            echo(f"Using secret from {token.source_path} to set org secret '{secret_name}' on {org} for {len(repos)} repo(s)")
            self.services.github.set_org_secret(org, secret_name, token.value, repos)
            self.services.registry.upsert_org_secret(
                org=org,
                secret_name=secret_name,
                token_file=str(token_file.expanduser()),
                repos=repos,
                last_token_refresh_at=timestamp,
            )
            refreshed_org_keys.add(key)

        for config in repo_targets:
            if config.secret_scope != "org":
                echo(f"Using secret from {token.source_path} to set repo secret '{config.secret_name}' on {config.repo}")
                self.services.github.set_secret(config.repo, config.secret_name, token.value)
            config.last_token_refresh_at = timestamp
            self.services.registry.upsert_repo(config)

        self.services.registry.save()
        echo(f"Refreshed token for {len(repo_targets)} repo(s) and {len(refreshed_org_keys)} org secret(s)")

    def repo_list(self, _args: argparse.Namespace) -> None:
        repos = sorted(self.services.registry.data["repos"].items())
        if not repos:
            echo("No repos registered.")
            return
        for name, data in repos:
            source = data.get("source", DEFAULT_SOURCE)
            template_ref = data.get("template_ref", DEFAULT_TEMPLATE_REF)
            path = data.get("path", "-")
            token = self.services.registry.token_label(data.get("token_file"))
            secret = self.secret_label({"repo": name, **data})
            echo(f"{name}\tsource={source}\tref={template_ref}\tpath={path}\tsecret={secret}\ttoken={token}")

    def repo_add(self, args: argparse.Namespace) -> None:
        repo = self.repo_or_detect_or_prompt(args.repo)
        existing = self.services.registry.repo(repo)
        source = args.source or (Prompts.text("Copier template source", DEFAULT_SOURCE) if sys.stdin.isatty() else DEFAULT_SOURCE)
        template_ref = args.template_ref or (Prompts.text("Copier template ref", DEFAULT_TEMPLATE_REF) if sys.stdin.isatty() else DEFAULT_TEMPLATE_REF)
        secret_name = args.secret_name or (Prompts.text("GitHub Actions secret name", DEFAULT_SECRET_NAME) if sys.stdin.isatty() else DEFAULT_SECRET_NAME)
        secret_scope = self.secret_scope_from_args(args, existing)
        secret_org = self.secret_org_for_repo(repo, secret_scope, args.org, existing)
        path = str(Path(args.path).expanduser()) if args.path else None
        if path is None and sys.stdin.isatty():
            path = Prompts.text("Local checkout path", existing.path if existing and existing.path else os.getcwd())
        token_file = (
            str(Path(args.token_file).expanduser())
            if args.token_file
            else self.services.tokens.resolve_repo_token_file(self.services.registry, args.token_name)
            if args.token_name
            else self.register_selected_token_file(
                self.token_file_or_prompt(None, None, existing.token_file if existing else None)
            )
        )
        timestamp = now_utc()
        self.services.registry.upsert_repo(
            RepoConfig(
                repo=repo,
                source=source,
                template_ref=template_ref,
                secret_name=secret_name,
                secret_scope=secret_scope,
                secret_org=secret_org,
                path=path if path is not None else (existing.path if existing else None),
                token_file=token_file,
                added_at=existing.added_at if existing else timestamp,
            )
        )
        if secret_scope == "org" and token_file:
            self.services.registry.upsert_org_secret(
                org=secret_org or split_repo(repo)[0],
                secret_name=secret_name,
                token_file=token_file,
                repos=[repo_name_for_org(repo, secret_org or split_repo(repo)[0])],
            )
        self.services.registry.save()
        echo(f"Saved {repo} to {self.services.registry.path}")

    def repo_remove(self, args: argparse.Namespace) -> None:
        repo = args.repo or self.prompt_or_error("Provide --repo.", "Repository (owner/repo)")
        self.services.registry.remove_repo(repo)
        self.services.registry.save()
        echo(f"Removed {repo} from {self.services.registry.path}")

    def repo_token(self, args: argparse.Namespace) -> None:
        repo = self.repo_or_detect_or_prompt(args.repo)
        existing = self.services.registry.repo(repo)

        selected_token_file: Path | None = None
        if args.token_file:
            selected_token_file = Path(args.token_file).expanduser()
        elif args.token_name:
            selected_token_file = token_file_for_name(args.token_name)
        elif sys.stdin.isatty():
            selected_token_file = self.prompt_for_token_file("Select token", existing.token_file if existing else None)
        elif existing and existing.token_file:
            selected_token_file = Path(existing.token_file).expanduser()

        secret_name_default = existing.secret_name if existing else DEFAULT_SECRET_NAME
        secret_name = args.secret_name or (
            Prompts.text("GitHub Actions secret name", secret_name_default)
            if sys.stdin.isatty()
            else secret_name_default
        )
        secret_scope = self.secret_scope_from_args(args, existing)
        secret_org = self.secret_org_for_repo(repo, secret_scope, args.org, existing)

        if selected_token_file:
            self.register_selected_token_file(selected_token_file)
            token = self.services.tokens.resolve_supplied(args.token, selected_token_file)
        elif args.token is not None:
            token_value = normalize_token(args.token)
            if not token_value:
                raise CIBotError("Token value is empty; refusing to continue.")
            token = TokenResult(token_value, None)
        else:
            token = self.services.tokens.resolve(None)
        timestamp = now_utc()
        self.set_secret_for_repo(repo, secret_name, secret_scope, secret_org, token, timestamp)
        self.services.registry.upsert_repo(
            RepoConfig(
                repo=repo,
                source=existing.source if existing else DEFAULT_SOURCE,
                template_ref=existing.template_ref if existing else DEFAULT_TEMPLATE_REF,
                secret_name=secret_name,
                secret_scope=secret_scope,
                secret_org=secret_org,
                path=existing.path if existing else None,
                token_file=token.source_path if token.source_path is not None else (existing.token_file if existing else None),
                added_at=existing.added_at if existing else timestamp,
                last_token_refresh_at=timestamp,
            )
        )
        self.services.registry.save()
        echo(f"Updated token for {repo}")

    def org_token(self, args: argparse.Namespace) -> None:
        org = args.org or self.prompt_or_error("Provide --org.", "Organization")
        secret_name = args.secret_name or (
            Prompts.text("GitHub Actions secret name", DEFAULT_SECRET_NAME)
            if sys.stdin.isatty()
            else DEFAULT_SECRET_NAME
        )
        repos = org_repo_names(args.repos or self.prompt_or_error("Provide --repos.", "Repos (comma separated)"), org)

        selected_token_file: Path | None = None
        if args.token_file:
            selected_token_file = Path(args.token_file).expanduser()
        elif args.token_name:
            selected_token_file = token_file_for_name(args.token_name)
        elif sys.stdin.isatty():
            existing = self.services.registry.data.get("org_secrets", {}).get(self.services.registry.org_secret_key(org, secret_name), {})
            selected_token_file = self.prompt_for_token_file("Select token", existing.get("token_file"))

        if selected_token_file:
            self.register_selected_token_file(selected_token_file)
            token = self.services.tokens.resolve_supplied(args.token, selected_token_file)
        elif args.token is not None:
            token_value = normalize_token(args.token)
            if not token_value:
                raise CIBotError("Token value is empty; refusing to continue.")
            token = TokenResult(token_value, None)
        else:
            token = self.services.tokens.resolve(None)

        timestamp = now_utc()
        echo(f"Using secret from {token.source_path or 'inline value'} to set org secret '{secret_name}' on {org} for {len(repos)} repo(s)")
        self.services.github.set_org_secret(org, secret_name, token.value, repos)
        self.services.registry.upsert_org_secret(
            org=org,
            secret_name=secret_name,
            token_file=token.source_path,
            repos=repos,
            last_token_refresh_at=timestamp,
        )
        for repo_name in repos:
            full_repo = f"{org}/{repo_name}"
            existing = self.services.registry.repo(full_repo)
            self.services.registry.upsert_repo(
                RepoConfig(
                    repo=full_repo,
                    source=existing.source if existing else DEFAULT_SOURCE,
                    template_ref=existing.template_ref if existing else DEFAULT_TEMPLATE_REF,
                    secret_name=secret_name,
                    secret_scope="org",
                    secret_org=org,
                    path=existing.path if existing else None,
                    token_file=token.source_path if token.source_path is not None else (existing.token_file if existing else None),
                    added_at=existing.added_at if existing else timestamp,
                    last_token_refresh_at=timestamp,
                )
            )
        self.services.registry.save()
        echo(f"Updated org secret {org}/{secret_name}")


# ---------------------------------------------------------------------------
# Parser and completion


def build_parser(commands: Commands) -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="ci-bot",
        description="Manage CI template setup and token refreshes for repositories.",
    )
    parser.add_argument(
        "--registry-file",
        default=str(DEFAULT_REGISTRY_PATH),
        help=f"Path to the ci-bot JSON registry. (default: {DEFAULT_REGISTRY_PATH})",
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    setup = subparsers.add_parser("setup", help="Apply template, set secret, and register repo")
    setup.add_argument("--repo", help="Repository slug (owner/repo). Auto-detected if omitted.")
    setup.add_argument("--source", help=f"Copier template source. (default: {DEFAULT_SOURCE})")
    setup.add_argument("--template-ref", help=f"Copier template ref. (default: {DEFAULT_TEMPLATE_REF})")
    setup.add_argument("--secret-name", help=f"GitHub Actions secret name. (default: {DEFAULT_SECRET_NAME})")
    setup.add_argument("--secret-scope", choices=SECRET_SCOPES, default="repo", help="Secret target scope. (default: repo)")
    setup.add_argument("--org", help="Organization for --secret-scope org. Defaults to the repo owner.")
    setup.add_argument("--token-file", help="Read token value from file.")
    setup.add_argument("--skip-secret", action="store_true", help="Skip setting the GitHub secret.")
    setup.add_argument("-i", "--interactive", action="store_true", help="Prompt for Copier template values instead of using defaults.")
    setup.set_defaults(func=commands.setup)

    update = subparsers.add_parser("update", help="Run copier update for a registered repo")
    update.add_argument("--repo", help="Repository slug (owner/repo). Auto-detected or prompts if omitted.")
    update.add_argument("--path", help="Repo path. Defaults to the registered path or cwd.")
    update.add_argument("--template-ref", help="Override the registered Copier ref.")
    update.add_argument("-i", "--interactive", action="store_true", help="Prompt for Copier values instead of using defaults.")
    update.set_defaults(func=commands.update)

    token = subparsers.add_parser("token", help="Manage local CI token files and refresh repo secrets")
    token_sub = token.add_subparsers(dest="token_command", required=True)

    token_add = token_sub.add_parser("add", help="Add a CI token file to the local token list")
    token_add.add_argument("name", nargs="?", help="Token name. Uses ~/.config/tokens/<name>.token when --token-file is omitted.")
    token_add.add_argument("--token-file", help="Token file to register or write.")
    token_add.add_argument("--token", help="Token value to save. Prompts if omitted when writing a token file.")
    token_add.set_defaults(func=commands.token_add)

    token_list = token_sub.add_parser("list", help="List token files referenced by registered repos")
    token_list.set_defaults(func=commands.token_list)

    token_show = token_sub.add_parser("show", help="Print a local CI token")
    token_show.add_argument("name", nargs="?", help="Token name. Uses ~/.config/tokens/<name>.token when --token-file is omitted. Prompts if needed.")
    token_show.add_argument("--token-file", help="Token file to print.")
    token_show.set_defaults(func=commands.token_show)

    token_refresh = token_sub.add_parser(
        "refresh",
        help="Update GitHub Actions secrets for repos using a token file",
        description="Updates GitHub Actions secrets for every registered repo that uses a given token file.",
    )
    token_refresh.add_argument("name", nargs="?", help="Token name. Uses ~/.config/tokens/<name>.token when --token-file is omitted. Prompts if needed.")
    token_refresh.add_argument("--token-file", help="Token file to save and refresh from.")
    token_refresh.add_argument("--token", help="Token value to save before refreshing repos. Prompts if omitted.")
    token_refresh.set_defaults(func=commands.token_refresh)

    repo = subparsers.add_parser("repo", help="Manage the local repo registry")
    repo_sub = repo.add_subparsers(dest="repo_command", required=True)

    repo_list = repo_sub.add_parser("list", help="List registered repos")
    repo_list.set_defaults(func=commands.repo_list)

    repo_add = repo_sub.add_parser("add", help="Add or update a repo in the local registry")
    repo_add.add_argument("--repo", help="Repository slug (owner/repo). Auto-detected or prompts if omitted.")
    repo_add.add_argument("--source", help=f"Copier template source. (default: {DEFAULT_SOURCE})")
    repo_add.add_argument("--template-ref", help=f"Copier template ref. (default: {DEFAULT_TEMPLATE_REF})")
    repo_add.add_argument("--secret-name", help=f"GitHub Actions secret name. (default: {DEFAULT_SECRET_NAME})")
    repo_add.add_argument("--secret-scope", choices=SECRET_SCOPES, help="Secret target scope. (default: repo, or existing value)")
    repo_add.add_argument("--org", help="Organization for --secret-scope org. Defaults to the repo owner.")
    repo_add.add_argument("--path", help="Optional local checkout path. Prompts if omitted.")
    repo_add.add_argument("--token-name", help="Token name. Uses ~/.config/tokens/<name>.token when --token-file is omitted.")
    repo_add.add_argument("--token-file", help="Optional token file for this repo. Prompts for --token-name behavior if omitted.")
    repo_add.set_defaults(func=commands.repo_add)

    repo_remove = repo_sub.add_parser("remove", help="Remove a repo from the local registry")
    repo_remove.add_argument("--repo", help="Repository slug (owner/repo). Prompts if omitted.")
    repo_remove.set_defaults(func=commands.repo_remove)

    repo_token = repo_sub.add_parser("token", help="Set a repo secret token without applying/updating templates")
    repo_token.add_argument("--repo", help="Repository slug (owner/repo). Auto-detected or prompts if omitted.")
    repo_token.add_argument("--secret-name", help="Override the secret name (defaults to registered value; prompts if omitted).")
    repo_token.add_argument("--secret-scope", choices=SECRET_SCOPES, help="Secret target scope. (default: repo, or existing value)")
    repo_token.add_argument("--org", help="Organization for --secret-scope org. Defaults to the repo owner.")
    repo_token.add_argument("--token-name", help="Token name. Uses ~/.config/tokens/<name>.token when --token-file is omitted.")
    repo_token.add_argument("--token-file", help="Read/save token using this file.")
    repo_token.add_argument("--token", help="Token value to save/use. Prompts if omitted.")
    repo_token.set_defaults(func=commands.repo_token)

    org = subparsers.add_parser("org", help="Manage organization-level secrets")
    org_sub = org.add_subparsers(dest="org_command", required=True)

    org_token = org_sub.add_parser("token", help="Set an organization secret for selected repos")
    org_token.add_argument("--org", required=True, help="GitHub organization.")
    org_token.add_argument("--repos", required=True, help="Comma-separated repo names or owner/repo slugs that can access the secret.")
    org_token.add_argument("--secret-name", help=f"GitHub Actions secret name. (default: {DEFAULT_SECRET_NAME})")
    org_token.add_argument("--token-name", help="Token name. Uses ~/.config/tokens/<name>.token when --token-file is omitted.")
    org_token.add_argument("--token-file", help="Read/save token using this file.")
    org_token.add_argument("--token", help="Token value to save/use. Prompts if omitted.")
    org_token.set_defaults(func=commands.org_token)

    return parser


def completion_items(words: list[str], cword: int) -> list[str]:
    if not words:
        return []

    current = words[cword] if cword < len(words) else ""
    prev = words[cword - 1] if cword > 0 else ""
    needs_path_value = {"--registry-file", "--token-file", "--path"}
    needs_scalar_value = {"--repo", "--source", "--template-ref", "--secret-name", "--secret-scope", "--org", "--repos", "--token", "--token-name"}

    if prev in needs_path_value:
        return ["__FILE__"]
    if prev in needs_scalar_value:
        return []

    root_commands = ["setup", "update", "token", "repo", "org"]
    root_options = ["-h", "--help", "--registry-file"]
    setup_options = ["--repo", "--source", "--template-ref", "--secret-name", "--secret-scope", "--org", "--token-file", "--skip-secret", "-i", "--interactive"]
    update_options = ["--repo", "--path", "--template-ref", "-i", "--interactive"]
    token_options = ["-h", "--help"]
    token_subcommands = ["add", "list", "show", "refresh"]
    token_add_options = ["--token-file", "--token"]
    token_show_options = ["--token-file"]
    token_refresh_options = ["--token-file", "--token"]
    repo_options = ["-h", "--help"]
    repo_subcommands = ["list", "add", "remove", "token"]
    repo_add_options = ["--repo", "--source", "--template-ref", "--secret-name", "--secret-scope", "--org", "--path", "--token-name", "--token-file"]
    repo_remove_options = ["--repo"]
    repo_token_options = ["--repo", "--secret-name", "--secret-scope", "--org", "--token-name", "--token-file", "--token"]
    org_options = ["-h", "--help"]
    org_subcommands = ["token"]
    org_token_options = ["--org", "--repos", "--secret-name", "--token-name", "--token-file", "--token"]

    state = "root"
    sub_cmd = None
    expect_value = False
    for token in words[1:cword]:
        if expect_value:
            expect_value = False
            continue
        if token in needs_path_value or token in needs_scalar_value:
            expect_value = True
            continue
        if state == "root":
            if token in root_commands:
                state = token
        elif state == "token":
            if token in token_subcommands:
                sub_cmd = token
                state = f"token_{token}"
        elif state == "repo":
            if token in repo_subcommands:
                sub_cmd = token
                state = f"repo_{token}"
        elif state == "org":
            if token in org_subcommands:
                sub_cmd = token
                state = f"org_{token}"

    if current.startswith("-"):
        return {
            "root": root_options,
            "setup": setup_options,
            "update": update_options,
            "token": token_options,
            "token_add": token_add_options,
            "token_show": token_show_options,
            "token_refresh": token_refresh_options,
            "repo": repo_options,
            "repo_add": repo_add_options,
            "repo_remove": repo_remove_options,
            "repo_token": repo_token_options,
            "org": org_options,
            "org_token": org_token_options,
        }.get(state, [])

    if state == "root":
        return root_commands + root_options
    if state == "token" and sub_cmd is None:
        return token_subcommands + token_options
    if state == "repo" and sub_cmd is None:
        return repo_subcommands + repo_options
    if state == "org" and sub_cmd is None:
        return org_subcommands + org_options
    return []


def emit_bash_source() -> None:
    script = r'''_ci_bot_completion() {
  local IFS=$'\n'
  local current_word="${COMP_WORDS[COMP_CWORD]}"
  local output
  output="$(_CI_BOT_COMPLETE=bash_complete COMP_WORDS="${COMP_WORDS[*]}" COMP_CWORD="$COMP_CWORD" ci-bot 2>/dev/null)"

  if [[ "$output" == "__FILE__" ]]; then
    COMPREPLY=( $(compgen -f -- "$current_word") )
  else
    COMPREPLY=( $(compgen -W "$output" -- "$current_word") )
  fi
}
complete -o default -F _ci_bot_completion ci-bot
'''
    print(script, end="")


def run_completion() -> int:
    mode = os.environ.get("_CI_BOT_COMPLETE")
    if not mode:
        return 1
    if mode == "bash_source":
        emit_bash_source()
        return 0
    if mode == "bash_complete":
        comp_words = os.environ.get("COMP_WORDS", "")
        comp_cword = int(os.environ.get("COMP_CWORD", "0") or "0")
        words = shlex.split(comp_words)
        if not words:
            words = ["ci-bot"]
        print("\n".join(completion_items(words, comp_cword)), end="")
        return 0
    return 1


def normalize_compat_argv(argv: list[str]) -> list[str]:
    if len(argv) >= 2 and argv[0] == "token" and argv[1] in {"set", "save"}:
        updated = list(argv)
        updated[1] = "add"
        return updated
    return argv


def main(argv: list[str] | None = None) -> int:
    if run_completion() == 0:
        return 0

    raw_argv = normalize_compat_argv(list(argv if argv is not None else sys.argv[1:]))
    services = Services(
        registry_path=DEFAULT_REGISTRY_PATH,
        github=GitHub(),
        copier=Copier(),
        tokens=TokenStore(),
    )
    commands = Commands(services)
    parser = build_parser(commands)

    try:
        args = parser.parse_args(raw_argv)
        services.registry_path = Path(args.registry_file).expanduser()
        args.func(args)
        return 0
    except KeyboardInterrupt:
        echo("Interrupted.", err=True)
        return 130
    except CIBotError as exc:
        echo(str(exc), err=True)
        return 1


if __name__ == "__main__":
    sys.exit(main())
