#!/usr/bin/env python3
"""Manage CI template setup and token distribution for GitHub repositories."""

from __future__ import annotations

import argparse
import getpass
import json
import os
import shlex
import subprocess
import sys
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path
from typing import Any


DEFAULT_SOURCE = "gh:athackst/ci"
DEFAULT_TEMPLATE_REF = "main"
DEFAULT_SECRET_NAME = "CI_BOT_TOKEN"
DEFAULT_TOKEN_FILE = Path("~/.config/tokens/ci_bot.token").expanduser()
DEFAULT_REGISTRY_PATH = Path("~/.config/ci_bot/repos.json").expanduser()


class CIBotError(Exception):
    """User-facing CLI error."""


@dataclass
class RepoConfig:
    repo: str
    source: str
    template_ref: str
    secret_name: str
    path: str | None = None
    token_file: str | None = None
    added_at: str | None = None
    last_setup_at: str | None = None
    last_update_at: str | None = None
    last_token_refresh_at: str | None = None

    def to_dict(self) -> dict[str, Any]:
        return {
            "source": self.source,
            "template_ref": self.template_ref,
            "secret_name": self.secret_name,
            "path": self.path,
            "token_file": self.token_file,
            "added_at": self.added_at,
            "last_setup_at": self.last_setup_at,
            "last_update_at": self.last_update_at,
            "last_token_refresh_at": self.last_token_refresh_at,
        }

    @classmethod
    def from_dict(cls, repo: str, data: dict[str, Any]) -> "RepoConfig":
        return cls(
            repo=repo,
            source=data.get("source", DEFAULT_SOURCE),
            template_ref=data.get("template_ref", DEFAULT_TEMPLATE_REF),
            secret_name=data.get("secret_name", DEFAULT_SECRET_NAME),
            path=data.get("path"),
            token_file=data.get("token_file"),
            added_at=data.get("added_at"),
            last_setup_at=data.get("last_setup_at"),
            last_update_at=data.get("last_update_at"),
            last_token_refresh_at=data.get("last_token_refresh_at"),
        )


def now_utc() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def echo(msg: str, err: bool = False) -> None:
    print(msg, file=sys.stderr if err else sys.stdout)


def require_cmd(cmd: str) -> None:
    if not shutil_which(cmd):
        raise CIBotError(f"Missing required command: {cmd}")


def shutil_which(cmd: str) -> str | None:
    for directory in os.environ.get("PATH", "").split(os.pathsep):
        candidate = Path(directory) / cmd
        if candidate.is_file() and os.access(candidate, os.X_OK):
            return str(candidate)
    return None


def run(cmd: list[str], cwd: str | None = None, capture_output: bool = False) -> str | None:
    try:
        completed = subprocess.run(
            cmd,
            cwd=cwd,
            check=True,
            text=True,
            capture_output=capture_output,
        )
    except subprocess.CalledProcessError as exc:
        stderr = (exc.stderr or "").strip()
        stdout = (exc.stdout or "").strip()
        detail = stderr or stdout or f"Command failed: {' '.join(cmd)}"
        raise CIBotError(detail) from exc
    if capture_output:
        return (completed.stdout or "").strip()
    return None


def detect_repo() -> str:
    require_cmd("gh")
    return run(["gh", "repo", "view", "--json", "nameWithOwner", "--jq", ".nameWithOwner"], capture_output=True)  # type: ignore[return-value]


def normalize_token(token: str) -> str:
    return token.strip()


def write_token_file(token_file: Path, token_value: str) -> str:
    token_file.parent.mkdir(parents=True, exist_ok=True)
    token_file.write_text(f"{token_value}\n", encoding="utf-8")
    echo(f"Saved token to {token_file}")
    return str(token_file)


def prompt_for_token() -> str:
    token_value = normalize_token(getpass.getpass("Enter CI token: "))
    if not token_value:
        raise CIBotError("Token value is empty; refusing to continue.")
    return token_value


def read_or_prompt_token(token_file: str | None) -> tuple[str, str | None]:
    requested_path = Path(token_file).expanduser() if token_file else None

    if requested_path and requested_path.is_file():
        return normalize_token(requested_path.read_text(encoding="utf-8")), str(requested_path)

    if requested_path:
        token_value = prompt_for_token()
        return token_value, write_token_file(requested_path, token_value)

    token_value = normalize_token(os.environ.get("CI_BOT_TOKEN", ""))
    if token_value:
        return token_value, None

    if DEFAULT_TOKEN_FILE.is_file():
        return normalize_token(DEFAULT_TOKEN_FILE.read_text(encoding="utf-8")), str(DEFAULT_TOKEN_FILE)

    token_value = prompt_for_token()
    return token_value, write_token_file(DEFAULT_TOKEN_FILE, token_value)


def resolve_supplied_token(token: str | None, token_file: Path) -> tuple[str, str]:
    if token is not None:
        token_value = normalize_token(token)
        if not token_value:
            raise CIBotError("Token value is empty; refusing to continue.")
        return token_value, write_token_file(token_file, token_value)

    if token_file.is_file():
        token_value = normalize_token(token_file.read_text(encoding="utf-8"))
        if token_value:
            return token_value, str(token_file)

    token_value = prompt_for_token()
    return token_value, write_token_file(token_file, token_value)


def resolve_token_value(token_file: str | None) -> tuple[str, str | None]:
    return read_or_prompt_token(token_file)


def load_registry(registry_path: Path) -> dict[str, Any]:
    if not registry_path.exists():
        return {"repos": {}}
    try:
        data = json.loads(registry_path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise CIBotError(f"Registry file is not valid JSON: {registry_path}") from exc
    if not isinstance(data, dict):
        raise CIBotError(f"Registry file must contain a JSON object: {registry_path}")
    data.setdefault("repos", {})
    if not isinstance(data["repos"], dict):
        raise CIBotError(f"Registry file 'repos' field must be an object: {registry_path}")
    return data


def save_registry(registry_path: Path, data: dict[str, Any]) -> None:
    registry_path.parent.mkdir(parents=True, exist_ok=True)
    registry_path.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n", encoding="utf-8")


def get_repo_config(registry: dict[str, Any], repo: str) -> RepoConfig | None:
    data = registry["repos"].get(repo)
    if data is None:
        return None
    return RepoConfig.from_dict(repo, data)


def upsert_repo_config(registry: dict[str, Any], config: RepoConfig) -> None:
    existing = registry["repos"].get(config.repo, {})
    merged = {**existing, **{k: v for k, v in config.to_dict().items() if v is not None}}
    registry["repos"][config.repo] = merged


def require_repo_config(registry: dict[str, Any], repo: str) -> RepoConfig:
    config = get_repo_config(registry, repo)
    if config is None:
        raise CIBotError(
            f"Repo '{repo}' is not registered. Run 'ci-bot setup' or 'ci-bot repo add --repo {repo}'."
        )
    return config


def apply_template(source: str, template_ref: str, interactive: bool, cwd: str) -> None:
    require_cmd("copier")
    cmd = ["copier", "copy", "--trust", "--vcs-ref", template_ref]
    if not interactive:
        cmd.append("--defaults")
    cmd.extend([source, "."])
    echo(f"Applying template {source}@{template_ref} in {cwd}")
    run(cmd, cwd=cwd)


def update_template(template_ref: str, interactive: bool, cwd: str) -> None:
    require_cmd("copier")
    cmd = ["copier", "update", "--trust", "--vcs-ref", template_ref]
    if not interactive:
        cmd.append("--defaults")
    echo(f"Updating template in {cwd} with ref {template_ref}")
    run(cmd, cwd=cwd)


def set_secret(repo: str, secret_name: str, token_value: str) -> None:
    require_cmd("gh")
    run(["gh", "secret", "set", secret_name, "--repo", repo, "--body", token_value])


def refresh_token_for_targets(
    registry_path: Path,
    token_file: Path,
    token_value: str,
) -> None:
    registry = load_registry(registry_path)
    normalized_token_file = str(token_file.expanduser())
    targets: list[RepoConfig] = []

    for repo_name in sorted(registry["repos"].keys()):
        config = get_repo_config(registry, repo_name)
        if config is None:
            continue
        if config.token_file == normalized_token_file:
            targets.append(config)

    if not targets:
        raise CIBotError(f"No registered repos use token file: {normalized_token_file}")

    timestamp = now_utc()

    for config in targets:
        echo(f"Using secret from {token_file} to set secret '{config.secret_name}' on {config.repo}")
        set_secret(config.repo, config.secret_name, token_value)
        config.last_token_refresh_at = timestamp
        upsert_repo_config(registry, config)

    save_registry(registry_path, registry)
    echo(f"Refreshed token for {len(targets)} repo(s)")


def cmd_setup(args: argparse.Namespace, registry_path: Path) -> None:
    require_cmd("git")
    repo = args.repo or detect_repo()
    cwd = os.getcwd()
    apply_template(args.source, args.template_ref, interactive=args.interactive, cwd=cwd)

    resolved_token_path = str(Path(args.token_file).expanduser()) if args.token_file else None
    token_value = None
    token_source_path = resolved_token_path
    if not args.skip_secret:
        token_value, token_source_path = resolve_token_value(resolved_token_path)
        echo(f"Using secret from {token_source_path} to set secret '{args.secret_name}' on {repo}")
        set_secret(repo, args.secret_name, token_value)

    registry = load_registry(registry_path)
    timestamp = now_utc()
    existing = get_repo_config(registry, repo)
    config = RepoConfig(
        repo=repo,
        source=args.source,
        template_ref=args.template_ref,
        secret_name=args.secret_name,
        path=cwd,
        token_file=token_source_path,
        added_at=existing.added_at if existing else timestamp,
        last_setup_at=timestamp,
        last_token_refresh_at=timestamp if token_value is not None else None,
    )
    upsert_repo_config(registry, config)
    save_registry(registry_path, registry)
    echo(f"Registered {repo} in {registry_path}")


def cmd_update(args: argparse.Namespace, registry_path: Path) -> None:
    repo = args.repo or detect_repo()
    registry = load_registry(registry_path)
    config = require_repo_config(registry, repo)

    target_path = Path(args.path).expanduser() if args.path else Path(config.path or os.getcwd()).expanduser()
    if not target_path.exists():
        raise CIBotError(
            f"Repo path does not exist: {target_path}. Re-run setup here or pass --path."
        )

    template_ref = args.template_ref or config.template_ref
    update_template(template_ref, interactive=args.interactive, cwd=str(target_path))

    config.path = str(target_path)
    config.template_ref = template_ref
    config.last_update_at = now_utc()
    upsert_repo_config(registry, config)
    save_registry(registry_path, registry)
    echo(f"Updated registry for {repo}")


def cmd_token_save(args: argparse.Namespace, _registry_path: Path) -> None:
    resolve_supplied_token(args.token, Path(args.token_file).expanduser())


def cmd_token_list(_args: argparse.Namespace, registry_path: Path) -> None:
    registry = load_registry(registry_path)
    token_files: dict[str, list[str]] = {}

    for repo_name in sorted(registry["repos"].keys()):
        config = get_repo_config(registry, repo_name)
        if config is None or not config.token_file:
            continue
        token_files.setdefault(config.token_file, []).append(repo_name)

    if not token_files:
        echo("No token files registered.")
        return

    for token_file, repos in sorted(token_files.items()):
        echo(f"{token_file}\t{len(repos)} repo(s)")


def cmd_token_refresh(args: argparse.Namespace, registry_path: Path) -> None:
    token_file = Path(args.token_file).expanduser()
    token_value, _ = resolve_supplied_token(args.token, token_file)
    refresh_token_for_targets(registry_path, token_file, token_value)


def cmd_repo_list(_args: argparse.Namespace, registry_path: Path) -> None:
    registry = load_registry(registry_path)
    repos = sorted(registry["repos"].items())
    if not repos:
        echo("No repos registered.")
        return
    for name, data in repos:
        source = data.get("source", DEFAULT_SOURCE)
        template_ref = data.get("template_ref", DEFAULT_TEMPLATE_REF)
        path = data.get("path", "-")
        echo(f"{name}\tsource={source}\tref={template_ref}\tpath={path}")


def cmd_repo_add(args: argparse.Namespace, registry_path: Path) -> None:
    registry = load_registry(registry_path)
    existing = get_repo_config(registry, args.repo)
    timestamp = now_utc()
    config = RepoConfig(
        repo=args.repo,
        source=args.source,
        template_ref=args.template_ref,
        secret_name=args.secret_name,
        path=str(Path(args.path).expanduser()) if args.path else (existing.path if existing else None),
        token_file=str(Path(args.token_file).expanduser()) if args.token_file else (existing.token_file if existing else None),
        added_at=existing.added_at if existing else timestamp,
    )
    upsert_repo_config(registry, config)
    save_registry(registry_path, registry)
    echo(f"Saved {args.repo} to {registry_path}")


def cmd_repo_remove(args: argparse.Namespace, registry_path: Path) -> None:
    registry = load_registry(registry_path)
    if registry["repos"].pop(args.repo, None) is None:
        raise CIBotError(f"Repo '{args.repo}' is not registered.")
    save_registry(registry_path, registry)
    echo(f"Removed {args.repo} from {registry_path}")


def cmd_repo_token(args: argparse.Namespace, registry_path: Path) -> None:
    repo = args.repo or detect_repo()
    registry = load_registry(registry_path)
    existing = get_repo_config(registry, repo)

    selected_token_file: Path | None = None
    if args.token_file:
        selected_token_file = Path(args.token_file).expanduser()
    elif existing and existing.token_file:
        selected_token_file = Path(existing.token_file).expanduser()

    if selected_token_file is not None:
        token_value, token_source_path = resolve_supplied_token(args.token, selected_token_file)
    elif args.token is not None:
        token_value = normalize_token(args.token)
        if not token_value:
            raise CIBotError("Token value is empty; refusing to continue.")
        token_source_path = None
    else:
        token_value, token_source_path = resolve_token_value(None)

    secret_name = args.secret_name or (existing.secret_name if existing else DEFAULT_SECRET_NAME)
    echo(f"Using secret from {token_source_path or 'inline value'} to set secret '{secret_name}' on {repo}")
    set_secret(repo, secret_name, token_value)

    timestamp = now_utc()
    config = RepoConfig(
        repo=repo,
        source=existing.source if existing else DEFAULT_SOURCE,
        template_ref=existing.template_ref if existing else DEFAULT_TEMPLATE_REF,
        secret_name=secret_name,
        path=existing.path if existing else None,
        token_file=token_source_path if token_source_path is not None else (existing.token_file if existing else None),
        added_at=existing.added_at if existing else timestamp,
        last_token_refresh_at=timestamp,
    )
    upsert_repo_config(registry, config)
    save_registry(registry_path, registry)
    echo(f"Updated token for {repo}")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="ci-bot",
        description="Manage CI template setup and token refreshes for repositories.",
    )
    parser.add_argument(
        "--registry-file",
        default=str(DEFAULT_REGISTRY_PATH),
        help=f"Path to the ci-bot JSON registry. (default: {DEFAULT_REGISTRY_PATH})",
    )

    subparsers = parser.add_subparsers(dest="command", required=True)

    setup = subparsers.add_parser("setup", help="Apply template, set secret, and register repo")
    setup.add_argument("--repo", help="Repository slug (owner/repo). Auto-detected if omitted.")
    setup.add_argument("--source", default=DEFAULT_SOURCE, help=f"Copier template source. (default: {DEFAULT_SOURCE})")
    setup.add_argument("--template-ref", default=DEFAULT_TEMPLATE_REF, help=f"Copier template ref. (default: {DEFAULT_TEMPLATE_REF})")
    setup.add_argument("--secret-name", default=DEFAULT_SECRET_NAME, help=f"GitHub Actions secret name. (default: {DEFAULT_SECRET_NAME})")
    setup.add_argument("--token-file", help="Read token value from file.")
    setup.add_argument("--skip-secret", action="store_true", help="Skip setting the GitHub secret.")
    setup.add_argument("-i", "--interactive", action="store_true", help="Prompt for Copier template values instead of using defaults.")
    setup.set_defaults(func=cmd_setup)

    update = subparsers.add_parser("update", help="Run copier update for a registered repo")
    update.add_argument("--repo", help="Repository slug (owner/repo). Defaults to the current repo.")
    update.add_argument("--path", help="Repo path. Defaults to the registered path or cwd.")
    update.add_argument("--template-ref", help="Override the registered Copier ref.")
    update.add_argument("-i", "--interactive", action="store_true", help="Prompt for Copier values instead of using defaults.")
    update.set_defaults(func=cmd_update)

    token = subparsers.add_parser("token", help="Manage local CI token files and refresh repo secrets")
    token_sub = token.add_subparsers(dest="token_command", required=True)

    token_save = token_sub.add_parser("save", help="Save a CI token to a local token file")
    token_save.add_argument("--token-file", required=True, help="Token file to write.")
    token_save.add_argument("--token", help="Token value to save. Prompts if omitted.")
    token_save.set_defaults(func=cmd_token_save)

    token_list = token_sub.add_parser("list", help="List token files referenced by registered repos")
    token_list.set_defaults(func=cmd_token_list)

    token_refresh = token_sub.add_parser("refresh", help="Save token and refresh all repos using that token file")
    token_refresh.add_argument("--token-file", required=True, help="Token file to save and refresh from.")
    token_refresh.add_argument("--token", help="Token value to save before refreshing repos. Prompts if omitted.")
    token_refresh.set_defaults(func=cmd_token_refresh)

    repo = subparsers.add_parser("repo", help="Manage the local repo registry")
    repo_sub = repo.add_subparsers(dest="repo_command", required=True)

    repo_list = repo_sub.add_parser("list", help="List registered repos")
    repo_list.set_defaults(func=cmd_repo_list)

    repo_add = repo_sub.add_parser("add", help="Add or update a repo in the local registry")
    repo_add.add_argument("--repo", required=True, help="Repository slug (owner/repo).")
    repo_add.add_argument("--source", default=DEFAULT_SOURCE, help=f"Copier template source. (default: {DEFAULT_SOURCE})")
    repo_add.add_argument("--template-ref", default=DEFAULT_TEMPLATE_REF, help=f"Copier template ref. (default: {DEFAULT_TEMPLATE_REF})")
    repo_add.add_argument("--secret-name", default=DEFAULT_SECRET_NAME, help=f"GitHub Actions secret name. (default: {DEFAULT_SECRET_NAME})")
    repo_add.add_argument("--path", help="Optional local checkout path.")
    repo_add.add_argument("--token-file", help="Optional token file for this repo.")
    repo_add.set_defaults(func=cmd_repo_add)

    repo_remove = repo_sub.add_parser("remove", help="Remove a repo from the local registry")
    repo_remove.add_argument("--repo", required=True, help="Repository slug (owner/repo).")
    repo_remove.set_defaults(func=cmd_repo_remove)

    repo_token = repo_sub.add_parser("token", help="Set a repo secret token without applying/updating templates")
    repo_token.add_argument("--repo", help="Repository slug (owner/repo). Defaults to the current repo.")
    repo_token.add_argument("--secret-name", help="Override the secret name (defaults to registered value).")
    repo_token.add_argument("--token-file", help="Read/save token using this file.")
    repo_token.add_argument("--token", help="Token value to save/use. Prompts if omitted.")
    repo_token.set_defaults(func=cmd_repo_token)

    return parser


def completion_items(words: list[str], cword: int) -> list[str]:
    if not words:
        return []

    current = words[cword] if cword < len(words) else ""
    prev = words[cword - 1] if cword > 0 else ""

    needs_path_value = {"--registry-file", "--token-file", "--path"}
    needs_scalar_value = {"--repo", "--source", "--template-ref", "--secret-name", "--token"}

    if prev in needs_path_value:
        return ["__FILE__"]
    if prev in needs_scalar_value:
        return []

    root_commands = ["setup", "update", "token", "repo"]
    root_options = ["-h", "--help", "--registry-file"]

    setup_options = ["--repo", "--source", "--template-ref", "--secret-name", "--token-file", "--skip-secret", "-i", "--interactive"]
    update_options = ["--repo", "--path", "--template-ref", "-i", "--interactive"]
    token_options = ["-h", "--help"]
    token_subcommands = ["save", "list", "refresh"]
    token_save_options = ["--token-file", "--token"]
    token_refresh_options = ["--token-file", "--token"]
    repo_options = ["-h", "--help"]
    repo_subcommands = ["list", "add", "remove", "token"]
    repo_add_options = ["--repo", "--source", "--template-ref", "--secret-name", "--path", "--token-file"]
    repo_remove_options = ["--repo"]
    repo_token_options = ["--repo", "--secret-name", "--token-file", "--token"]

    state = "root"
    sub_cmd = None
    expect_value = False

    for token in words[1:cword]:
        if expect_value:
            expect_value = False
            continue

        if token in needs_path_value or token in needs_scalar_value:
            expect_value = True
            continue

        if state == "root":
            if token in root_commands:
                state = token
        elif state == "token":
            if token in token_subcommands:
                sub_cmd = token
                state = f"token_{token}"
        elif state == "repo":
            if token in repo_subcommands:
                sub_cmd = token
                state = f"repo_{token}"

    if current.startswith("-"):
        if state == "root":
            return root_options
        if state == "setup":
            return setup_options
        if state == "update":
            return update_options
        if state == "token":
            return token_options
        if state == "token_save":
            return token_save_options
        if state == "token_refresh":
            return token_refresh_options
        if state == "repo":
            return repo_options
        if state == "repo_add":
            return repo_add_options
        if state == "repo_remove":
            return repo_remove_options
        if state == "repo_token":
            return repo_token_options

    if state == "root":
        return root_commands + root_options
    if state == "token" and sub_cmd is None:
        return token_subcommands + token_options
    if state == "repo" and sub_cmd is None:
        return repo_subcommands + repo_options

    return []


def emit_bash_source() -> None:
    script = r'''_ci_bot_completion() {
  local IFS=$'\n'
  local current_word="${COMP_WORDS[COMP_CWORD]}"
  local output
  output="$(_CI_BOT_COMPLETE=bash_complete COMP_WORDS="${COMP_WORDS[*]}" COMP_CWORD="$COMP_CWORD" ci-bot 2>/dev/null)"

  if [[ "$output" == "__FILE__" ]]; then
    COMPREPLY=( $(compgen -f -- "$current_word") )
  else
    COMPREPLY=( $(compgen -W "$output" -- "$current_word") )
  fi
}
complete -o default -F _ci_bot_completion ci-bot
'''
    print(script, end="")


def run_completion() -> int:
    mode = os.environ.get("_CI_BOT_COMPLETE")
    if not mode:
        return 1

    if mode == "bash_source":
        emit_bash_source()
        return 0

    if mode == "bash_complete":
        comp_words = os.environ.get("COMP_WORDS", "")
        comp_cword = int(os.environ.get("COMP_CWORD", "0") or "0")
        words = shlex.split(comp_words)
        if not words:
            words = ["ci-bot"]
        items = completion_items(words, comp_cword)
        print("\n".join(items), end="")
        return 0

    return 1


def normalize_compat_argv(argv: list[str]) -> list[str]:
    # Backward compatibility: `ci-bot token set` -> `ci-bot token save`.
    if len(argv) >= 2 and argv[0] == "token" and argv[1] == "set":
        updated = list(argv)
        updated[1] = "save"
        return updated
    return argv


def main(argv: list[str] | None = None) -> int:
    completion_rc = run_completion()
    if completion_rc == 0:
        return 0

    parser = build_parser()

    try:
        args = parser.parse_args(normalize_compat_argv(list(argv if argv is not None else sys.argv[1:])))
        registry_path = Path(args.registry_file).expanduser()
        args.func(args, registry_path)
        return 0
    except KeyboardInterrupt:
        echo("Interrupted.", err=True)
        return 130
    except CIBotError as exc:
        echo(str(exc), err=True)
        return 1


if __name__ == "__main__":
    sys.exit(main())
